# ─── Email credentials ────────────────────────────────────────────────────────
# Gmail address that SENDS the contact form emails (your sending account).
# This can be any Gmail you control — it does NOT have to be your main inbox.
# If you use 2-Factor Authentication (recommended), generate an App Password:
#   Google Account → Security → 2-Step Verification → App passwords
#   Name it "Portfolio Contact Form", copy the 16-char password below.
SMTP_USER=your-sending-gmail@gmail.com
SMTP_PASS=your-16-char-app-password

# ─── Where contact form messages are delivered ────────────────────────────────
CONTACT_TO=mwangihenry622@gmail.com

# ─── Server ───────────────────────────────────────────────────────────────────
PORT=3001

# ─── CORS — which frontend origins are allowed to call this API ───────────────
# In development, your static site on localhost (e.g. python3 -m http.server 8000)
# In production, replace with your actual deployed domain e.g. https://henrymaina.com
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ─── Optional: reply-to behaviour ────────────────────────────────────────────
# When you hit "Reply" on a received contact email, it replies to the sender.
# Set to "true" to enable (recommended). Set to "false" to reply to SMTP_USER.
REPLY_TO_SENDER=true
